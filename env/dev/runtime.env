## Canonical development runtime env
## Minimal active Rust runtime contract (unused legacy keys removed).

# Core runtime
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SESSION_COOKIE_NAME=bominal_session
SESSION_COOKIE_DOMAIN=
STEP_UP_TTL_SECONDS=600
PROVIDER_AUTH_PROBE_ENABLED=true
USER_APP_HOST=www.bominal.com
ADMIN_APP_HOST=ops.bominal.com
UI_THEME_COOKIE_NAME=bominal_theme
STATION_CATALOG_JSON_PATH=data/train/station_catalog.v1.json
STATION_CATALOG_SOURCE_MODE=repo_only
LOG_JSON=false
FRONTEND_ASSETS_DIR=/workspace/runtime/frontend/dist
HTTP_REQUEST_TIMEOUT_SECONDS=30
HTTP_REQUEST_BODY_LIMIT_BYTES=2097152
HTTP_CONCURRENCY_LIMIT=32
ADMIN_EMAILS=admin@bominal.local

# Database
DATABASE_URL=postgresql+asyncpg://bominal:bominal@postgres:5432/bominal

# Redis queue/runtime contracts
REDIS_URL=redis://redis:6379/0
RUNTIME_QUEUE_KEY=train:queue
RUNTIME_QUEUE_DLQ_KEY=train:queue:dlq
RUNTIME_LEASE_PREFIX=train:lease
RUNTIME_RATE_LIMIT_PREFIX=rate_limit

# Internal service token auth
INTERNAL_IDENTITY_SECRET=dev-internal-identity-secret
INTERNAL_IDENTITY_ISSUER=bominal-internal

# Envelope encryption
KEK_VERSION=1
MASTER_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
MASTER_KEY_OVERRIDE=

# Email / Resend / Evervault
EMAIL_FROM_ADDRESS=no-reply@bominal.local
RESEND_API_KEY=
# Backward compatibility alias consumed by runtime code.
RESEND_BASE_URL=https://api.resend.com
# Backward compatibility alias consumed by runtime code.
EVERVAULT_RELAY_BASE_URL=https://relay.evervault.com
EVERVAULT_APP_ID=

# Worker cadence
WORKER_POLL_SECONDS=3
WORKER_RECONCILE_SECONDS=30
WORKER_WATCH_SECONDS=5
KEY_ROTATION_SECONDS=3600

# Password hashing worker semaphore
PASSWORD_HASH_CONCURRENCY=1
