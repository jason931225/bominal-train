# Copy to env/prod/cloudrun-api.env before running runtime/cloudrun/api/bootstrap.sh.
# Future Cloud Run API cutover only. Current production remains VM-first.
# Policy: max 5 active GSM secrets at all times. Adding one requires removing another.
# Because of that policy, REDIS_URL stays a plain Cloud Run env value by default.

# Cloud Run service identity / image
CLOUDRUN_API_SERVICE=bominal-api
CLOUDRUN_API_REGION=us-central1
CLOUDRUN_API_IMAGE=us-central1-docker.pkg.dev/CHANGE_ME_PROJECT/CHANGE_ME_REPO/bominal-api:CHANGE_ME_TAG
CLOUDRUN_API_SERVICE_ACCOUNT=bominal-api@CHANGE_ME_PROJECT.iam.gserviceaccount.com

# Direct VPC egress
CLOUDRUN_API_VPC_NETWORK=CHANGE_ME_VPC_NETWORK
CLOUDRUN_API_VPC_SUBNET=CHANGE_ME_VPC_SUBNET
CLOUDRUN_API_VPC_NETWORK_TAGS=

# Service shape
CLOUDRUN_API_MIN_INSTANCES=0
CLOUDRUN_API_MAX_INSTANCES=1
CLOUDRUN_API_CONTAINER_CONCURRENCY=4
CLOUDRUN_API_TIMEOUT_SECONDS=35
CLOUDRUN_API_CPU=1
CLOUDRUN_API_MEMORY=512Mi
CLOUDRUN_API_STARTUP_CPU_BOOST=true

# Plain Cloud Run env (not GSM)
USER_APP_HOST=www.bominal.com
ADMIN_APP_HOST=ops.bominal.com
SESSION_COOKIE_DOMAIN=.bominal.com
INVITE_BASE_URL=https://CHANGE_ME_PUBLIC_BASE_URL
EMAIL_FROM_ADDRESS=no-reply@CHANGE_ME_RESEND_DOMAIN
WEBAUTHN_RP_ID=CHANGE_ME_RP_ID
WEBAUTHN_RP_ORIGIN=https://CHANGE_ME_PUBLIC_BASE_URL
REDIS_URL=redis://CHANGE_ME_VM_INTERNAL_IP:6379/0
HTTP_REQUEST_TIMEOUT_SECONDS=30
HTTP_REQUEST_BODY_LIMIT_BYTES=2097152
HTTP_CONCURRENCY_LIMIT=4
PASSWORD_HASH_CONCURRENCY=1
API_DB_POOL_MAX_CONNECTIONS=4
DB_POOL_ACQUIRE_TIMEOUT_SECONDS=2
DB_POOL_IDLE_TIMEOUT_SECONDS=60
DB_POOL_MAX_LIFETIME_SECONDS=300

# Google Secret Manager secret names (max 5 active secrets total)
GSM_DATABASE_URL_SECRET=DATABASE_URL
GSM_SESSION_SECRET_SECRET=SESSION_SECRET
GSM_INTERNAL_IDENTITY_SECRET_SECRET=INTERNAL_IDENTITY_SECRET
GSM_MASTER_KEY_SECRET=MASTER_KEY
GSM_RESEND_API_KEY_SECRET=RESEND_API_KEY
