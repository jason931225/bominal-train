# Copy to env/prod/runtime.env before running production runtime.
# Minimal active Rust runtime contract (unused legacy keys removed).

# Core runtime
APP_ENV=production
LOG_JSON=true
FRONTEND_ASSETS_DIR=/workspace/runtime/frontend/dist
SESSION_COOKIE_DOMAIN=.bominal.com
STEP_UP_TTL_SECONDS=600
PROVIDER_AUTH_PROBE_ENABLED=true
USER_APP_HOST=www.bominal.com
ADMIN_APP_HOST=ops.bominal.com
UI_THEME_COOKIE_NAME=bominal_theme
STATION_CATALOG_JSON_PATH=data/train/station_catalog.v1.json
STATION_CATALOG_SOURCE_MODE=repo_only
HTTP_REQUEST_TIMEOUT_SECONDS=30
HTTP_REQUEST_BODY_LIMIT_BYTES=2097152
HTTP_CONCURRENCY_LIMIT=4
ADMIN_EMAILS=admin@CHANGE_ME_DOMAIN
INVITE_BASE_URL=https://CHANGE_ME_PUBLIC_BASE_URL
SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# Database
DATABASE_URL=postgresql+asyncpg://bominal:CHANGE_ME_DB_PASSWORD@CHANGE_ME_DB_HOST:5432/bominal
API_DB_POOL_MAX_CONNECTIONS=4
WORKER_DB_POOL_MAX_CONNECTIONS=3
DB_POOL_ACQUIRE_TIMEOUT_SECONDS=2
DB_POOL_IDLE_TIMEOUT_SECONDS=60
DB_POOL_MAX_LIFETIME_SECONDS=300

# Redis queue/runtime contracts
REDIS_URL=redis://redis:6379/0
RUNTIME_QUEUE_KEY=train:queue
RUNTIME_QUEUE_DLQ_KEY=train:queue:dlq
RUNTIME_LEASE_PREFIX=train:lease
RUNTIME_RATE_LIMIT_PREFIX=rate_limit

# Internal service token auth
INTERNAL_IDENTITY_SECRET=CHANGE_ME_INTERNAL_IDENTITY_SECRET
INTERNAL_IDENTITY_ISSUER=bominal-internal

# Passkeys (server-side WebAuthn)
PASSKEY_PROVIDER=server_webauthn
WEBAUTHN_RP_ID=CHANGE_ME_RP_ID
WEBAUTHN_RP_ORIGIN=https://CHANGE_ME_PUBLIC_BASE_URL
WEBAUTHN_RP_NAME=bominal
WEBAUTHN_CHALLENGE_TTL_SECONDS=300

# Envelope encryption
KEK_VERSION=1
# Base64-encoded 32-byte key. Generate with: openssl rand -base64 32
MASTER_KEY=CHANGE_ME_BASE64_32BYTE_KEY
# Optional deploy-time override when key source is external.
MASTER_KEY_OVERRIDE=

# Email / Resend / Evervault
EMAIL_FROM_ADDRESS=no-reply@CHANGE_ME_RESEND_DOMAIN
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
# Backward compatibility alias consumed by runtime code.
RESEND_BASE_URL=https://api.resend.com
# Backward compatibility alias consumed by runtime code.
EVERVAULT_RELAY_BASE_URL=https://relay.evervault.com
EVERVAULT_APP_ID=

# Worker cadence
WORKER_POLL_SECONDS=1
WORKER_RECONCILE_SECONDS=30
WORKER_WATCH_SECONDS=60
KEY_ROTATION_SECONDS=3600

# Password hashing worker semaphore (recommended default: 1)
PASSWORD_HASH_CONCURRENCY=1
