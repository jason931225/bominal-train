# Copy to infra/env/prod/runtime.env before running production runtime.
# Minimal active Rust runtime contract (unused legacy keys removed).

# Core runtime
APP_ENV=production
LOG_JSON=true
FRONTEND_ASSETS_DIR=/workspace/runtime/frontend/dist

# Database
DATABASE_URL=postgresql+asyncpg://postgres.CHANGE_ME_PROJECT_REF:CHANGE_ME_DB_PASSWORD@aws-0-us-central1.pooler.supabase.co:5432/postgres?ssl=require

# Supabase JWT verification + auth webhook validation
SUPABASE_URL=CHANGE_ME_SUPABASE_URL
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=CHANGE_ME_SUPABASE_JWT_ISSUER
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_CACHE_SECONDS=300
SUPABASE_AUTH_WEBHOOK_SECRET=CHANGE_ME_SUPABASE_AUTH_WEBHOOK_SECRET

# Redis queue/runtime contracts
REDIS_URL=redis://redis:6379/0
RUNTIME_QUEUE_KEY=train:queue
RUNTIME_QUEUE_DLQ_KEY=train:queue:dlq
RUNTIME_LEASE_PREFIX=train:lease
RUNTIME_RATE_LIMIT_PREFIX=rate_limit

# Internal service token auth
INTERNAL_IDENTITY_SECRET=CHANGE_ME_INTERNAL_IDENTITY_SECRET
INTERNAL_IDENTITY_ISSUER=bominal-internal

# Envelope encryption
KEK_VERSION=1
# Base64-encoded 32-byte key. Generate with: openssl rand -base64 32
MASTER_KEY=CHANGE_ME_BASE64_32BYTE_KEY
# Optional deploy-time override when key source is external.
MASTER_KEY_OVERRIDE=

# Email / Resend / Evervault
EMAIL_FROM_ADDRESS=no-reply@CHANGE_ME_RESEND_DOMAIN
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
# Backward compatibility alias consumed by runtime code.
RESEND_BASE_URL=https://api.resend.com
# Backward compatibility alias consumed by runtime code.
EVERVAULT_RELAY_BASE_URL=https://relay.evervault.com
EVERVAULT_APP_ID=

# Worker cadence
WORKER_POLL_SECONDS=3
WORKER_RECONCILE_SECONDS=30
WORKER_WATCH_SECONDS=5
KEY_ROTATION_SECONDS=3600
