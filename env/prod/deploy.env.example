# Deployment control-variable reference for the active GitHub Actions CD flow.
# Canonical storage is GitHub Environment "production" variables.
# Keep local operator copies out of git as env/prod/deploy.env when needed.

# Optional auto-deploy switch for pushes to main (must be exactly "true" to enable).
AUTO_DEPLOY_MAIN=false

# Required GCP OIDC + target VM settings.
GCP_PROJECT_ID=CHANGE_ME_GCP_PROJECT_ID
GCP_WORKLOAD_IDENTITY_PROVIDER=projects/CHANGE_ME_PROJECT_NUMBER/locations/global/workloadIdentityPools/CHANGE_ME_POOL/providers/CHANGE_ME_PROVIDER
GCP_SERVICE_ACCOUNT=CHANGE_ME_SA@CHANGE_ME_GCP_PROJECT_ID.iam.gserviceaccount.com
DEPLOY_VM_NAME=CHANGE_ME_DEPLOY_VM_NAME
DEPLOY_VM_ZONE=CHANGE_ME_DEPLOY_VM_ZONE

# Required VM paths used by CD remote execution.
DEPLOY_WORKDIR=CHANGE_ME_DEPLOY_WORKDIR_ABS_PATH
DEPLOY_SCRIPT_PATH=CHANGE_ME_DEPLOY_SCRIPT_ABS_PATH
DEPLOY_HEALTHCHECK_SCRIPT_PATH=CHANGE_ME_HEALTHCHECK_SCRIPT_ABS_PATH
DEPLOY_ROLLBACK_SCRIPT_PATH=CHANGE_ME_ROLLBACK_SCRIPT_ABS_PATH
VM_SECRET_ENV_FILE=CHANGE_ME_VM_SECRET_ENV_ABS_PATH
DEPLOY_RUNTIME_ENV_FILE=CHANGE_ME_RUNTIME_ENV_ABS_PATH
DEPLOY_COMPOSE_FILE=CHANGE_ME_COMPOSE_FILE_ABS_PATH
DEPLOY_MIGRATIONS_DIR=CHANGE_ME_MIGRATIONS_DIR_ABS_PATH

# Required service and healthcheck contract values.
DEPLOY_API_SERVICE=api
DEPLOY_WORKER_SERVICE=worker
DEPLOY_HEALTHCHECK_LIVE_URL=http://127.0.0.1:8000/health/live
DEPLOY_HEALTHCHECK_READY_URL=http://127.0.0.1:8000/health/ready

# Required self-hosted Postgres settings exported to deploy script.
POSTGRES_HOST=CHANGE_ME_POSTGRES_HOST
POSTGRES_PORT=5432
POSTGRES_DB=bominal
POSTGRES_USER=bominal

# Production VM secret env file contract (value file is on VM, not in git):
# - VM_SECRET_ENV_FILE should point to a root-readable file with mode 0600.
# - Deploy script bootstraps this file if missing and stores BOMINAL_DATABASE_URL.
# - Provide one of:
#   1) BOMINAL_DATABASE_URL=postgresql+asyncpg://...
#   2) BOMINAL_POSTGRES_PASSWORD=...

# Optional deploy tuning (set in GitHub variables only if needed):
# DEPLOY_HEALTHCHECK_RETRIES=20
# DEPLOY_HEALTHCHECK_DELAY_SECONDS=3
# DEPLOY_COMPOSE_PROJECT_NAME=bominal
# DEPLOY_ROLLBACK_STATE_PATH=/opt/bominal/repo/.deploy/rollback.env
# DEPLOY_VM_BASELINE_SCRIPT=/opt/bominal/repo/scripts/prod/ensure-vm-baseline.sh
