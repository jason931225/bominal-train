# Deployment control-variable reference for the active GitHub Actions CD flow.
# Canonical storage is GitHub Environment "production" variables.
# Keep local operator copies out of git as env/prod/deploy.env when needed.

# Optional auto-deploy switch for pushes to main (must be exactly "true" to enable).
AUTO_DEPLOY_MAIN=false

# Required GCP OIDC + target VM settings.
GCP_PROJECT_ID=CHANGE_ME_GCP_PROJECT_ID
GCP_WORKLOAD_IDENTITY_PROVIDER=projects/CHANGE_ME_PROJECT_NUMBER/locations/global/workloadIdentityPools/CHANGE_ME_POOL/providers/CHANGE_ME_PROVIDER
GCP_SERVICE_ACCOUNT=CHANGE_ME_SA@CHANGE_ME_GCP_PROJECT_ID.iam.gserviceaccount.com
DEPLOY_VM_NAME=CHANGE_ME_DEPLOY_VM_NAME
DEPLOY_VM_ZONE=CHANGE_ME_DEPLOY_VM_ZONE

# Production VM bootstrap TODO (run once; command is idempotent and safe to re-run):
# - Ensure /swapfile exists at 2G and is active.
# - Ensure these kernel settings are applied and persisted:
#   - vm.swappiness=10
#   - vm.vfs_cache_pressure=50
# sudo bash -lc 'set -euo pipefail; SWAP=/swapfile; if ! /sbin/swapon --show=NAME --noheadings | grep -qx "$SWAP"; then if [ ! -f "$SWAP" ]; then fallocate -l 2G "$SWAP" || dd if=/dev/zero of="$SWAP" bs=1M count=2048 status=none; fi; chmod 600 "$SWAP"; mkswap "$SWAP" >/dev/null; /sbin/swapon "$SWAP"; fi; grep -qE "^/swapfile[[:space:]]" /etc/fstab || echo "/swapfile none swap sw 0 0" >> /etc/fstab; printf "vm.swappiness=10\nvm.vfs_cache_pressure=50\n" > /etc/sysctl.d/99-bominal-swap.conf; /sbin/sysctl -w vm.swappiness=10 >/dev/null; /sbin/sysctl -w vm.vfs_cache_pressure=50 >/dev/null'
# Recommended: bake the same guard into DEPLOY_COMMAND as a prefix so every deploy enforces baseline VM memory config.

# Required fail-closed single-line commands consumed by .github/workflows/cd.yml.
# CD exports immutable image refs before DEPLOY_COMMAND runs:
# - BOMINAL_API_IMAGE
# - BOMINAL_WORKER_IMAGE
DEPLOY_COMMAND=CHANGE_ME_SINGLE_LINE_DEPLOY_COMMAND
DEPLOY_HEALTHCHECK_COMMAND=CHANGE_ME_SINGLE_LINE_HEALTHCHECK_COMMAND
