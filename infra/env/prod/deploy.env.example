# Optional local deployment credentials for registry-auth helper workflows.
# Keep this file out of git as infra/env/prod/deploy.env
GHCR_NAMESPACE=ghcr.io/jason931225/bominal
GHCR_USERNAME=CHANGE_ME_GHCR_USERNAME
GHCR_TOKEN=CHANGE_ME_GHCR_TOKEN
# Post-verify Docker cleanup controls on production VM.
DEPLOY_DOCKER_PRUNE_UNUSED_IMAGES=true
DEPLOY_DOCKER_PRUNE_BUILD_CACHE=true
# Optional retention cap for bominal images; when >0, keeps latest N tags (plus running images)
# and skips full `docker image prune -a`.
DEPLOY_DOCKER_KEEP_BOMINAL_IMAGES=0
