RESTAURANT_OPENTABLE_SEARCH_SLOT_PATH=data.availability
RESTAURANT_OPENTABLE_CREATE_OPERATION_NAME=BookDetailsStandardSlotLock
RESTAURANT_OPENTABLE_CREATE_OPERATION_SHA256=1100bf68905fd7cb1d4fd0f4504a4954aa28ec45fb22913fa977af8b06fd97fa
RESTAURANT_OPENTABLE_CREATE_PATH=/dapi/booking/make-reservation
RESTAURANT_OPENTABLE_CONFIRMATION_OPERATION_NAME=BookingConfirmationPageInFlow
RESTAURANT_OPENTABLE_CONFIRMATION_OPERATION_SHA256=6be25f0bbc8fe75483bdfe96ae78fb20075b978842e4b44964aed3591611aa99
RESTAURANT_RESY_BASE_URL=https://api.resy.com
RESTAURANT_RESY_TIMEOUT_SECONDS=20
RESTAURANT_RESY_AUTH_PASSWORD_PATH=/4/auth/password
RESTAURANT_RESY_AUTH_API_KEY=
RESTAURANT_RESY_X_ORIGIN=https://resy.com
RESTAURANT_RESY_PROFILE_PATH=/2/user
RESTAURANT_RESY_SEARCH_PATH=/4/find
RESTAURANT_RESY_CREATE_DETAILS_PATH=/3/details
RESTAURANT_RESY_CREATE_BOOK_PATH=/3/book
RESTAURANT_RESY_CANCEL_PATH=/3/cancel
RESTAURANT_RESY_SOURCE_ID=resy.com-venue-details
RESTAURANT_RESY_REFRESH_PATH=/3/auth/refresh
RESTAURANT_RESY_LOGOUT_PATH=/3/auth/logout
PAYMENT_CVV_TTL_SECONDS=3600
EMAIL_PROVIDER=disabled
EMAIL_FROM_NAME=bominal
