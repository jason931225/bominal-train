# Copy to infra/env/prod/api.env before running production compose
APP_ENV=production
# Optional override for deploy.sh image namespace (default: ghcr.io/jason931225/bominal).
GHCR_NAMESPACE=ghcr.io/jason931225/bominal
DATABASE_URL=postgresql+asyncpg://postgres.CHANGE_ME_PROJECT_REF:CHANGE_ME_DB_PASSWORD@aws-0-us-central1.pooler.supabase.co:5432/postgres?ssl=require
SYNC_DATABASE_URL=postgresql+psycopg://postgres.CHANGE_ME_PROJECT_REF:CHANGE_ME_DB_PASSWORD@aws-0-us-central1.pooler.supabase.co:5432/postgres?sslmode=require
CORS_ORIGINS=https://www.bominal.com
SESSION_COOKIE_NAME=bominal_session
SESSION_DAYS_DEFAULT=7
SESSION_DAYS_REMEMBER=90
# Argon2id profile tuned for e2-micro class instances.
PASSWORD_HASH_TIME_COST=2
PASSWORD_HASH_MEMORY_COST_KIB=16384
PASSWORD_HASH_PARALLELISM=1
# legacy | supabase
AUTH_MODE=supabase
SUPABASE_URL=CHANGE_ME_SUPABASE_URL
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=CHANGE_ME_SUPABASE_JWT_ISSUER
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_AUTH_ENABLED=true
SUPABASE_AUTH_API_KEY=CHANGE_ME_SUPABASE_AUTH_API_KEY
SUPABASE_AUTH_TIMEOUT_SECONDS=12
SUPABASE_STORAGE_ENABLED=true
SUPABASE_STORAGE_BUCKET=artifacts-safe
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SUPABASE_SERVICE_ROLE_KEY
PASSKEY_ENABLED=true
PASSKEY_RP_ID=www.bominal.com
PASSKEY_ORIGIN=https://www.bominal.com
PASSKEY_TIMEOUT_MS=60000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_USE_REDIS=1
# Non-CDE Redis (queues/rate limits/safe cache)
REDIS_URL=redis://redis:6379/0
# Optional explicit split URLs.
# If REDIS_URL_CDE is empty, REDIS_URL is used for CDE; it MUST NOT be Upstash.
REDIS_URL_NON_CDE=
REDIS_URL_CDE=
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_API_KEY
# Optional short-lived internal service token signing key.
INTERNAL_IDENTITY_SECRET=
INTERNAL_IDENTITY_ISSUER=bominal-internal
INTERNAL_IDENTITY_TTL_SECONDS=120
# Generate with: openssl rand -base64 32
MASTER_KEY=CHANGE_ME_BASE64_32_BYTES
# Optional keyring JSON for decrypting legacy KEK versions during rotation.
# Example: {"1":"<old_base64_32>","2":"<current_base64_32>"}
MASTER_KEYS_BY_VERSION=
KEK_VERSION=1
# Minimum number of days to retain a retired KEK after rewrap completion.
KEK_RETIREMENT_WINDOW_DAYS=30
TRAIN_PROVIDER_MODE=real
TRAIN_PROVIDER_TRANSPORT=curl_cffi
# Optional internal egress gateways for strict outbound provider routing.
TRAIN_PROVIDER_EGRESS_PROXY_URL=http://egress-train:8080
TRAIN_KTX_ENABLED=false
RESTAURANT_MODULE_ENABLED=false
# Enable only when restaurant module rollout is active:
# RESTAURANT_PROVIDER_EGRESS_PROXY_URL=http://egress-restaurant:8080
TRAIN_POLL_MIN_SECONDS=2
TRAIN_POLL_MAX_SECONDS=6
TRAIN_POLL_FORCE_MAX_RATE=false
TRAIN_CREDENTIAL_VERIFY_TIMEOUT_SECONDS=8
TRAIN_CREDENTIAL_CACHE_SECONDS=3600
TRAIN_PERSIST_ALL_ATTEMPTS=false
TRAIN_ATTEMPT_RETENTION_DAYS=30
TRAIN_COMPACT_REPETITIVE_ATTEMPTS=true
TRAIN_SYNC_KEEP_LATEST_ONLY=true
RESTAURANT_AUTH_REFRESH_RETRIES=2
RESTAURANT_PAYMENT_LEASE_TTL_SECONDS=120
RESTAURANT_BOOTSTRAP_TIMEOUT_SECONDS=20
PAYMENT_ENABLED=true
PAYMENT_CVV_TTL_SECONDS=600
PAYMENT_CVV_TTL_MIN_SECONDS=60
PAYMENT_CVV_TTL_MAX_SECONDS=900
PAYMENT_PROVIDER_ALLOWED_HOSTS=app.srail.or.kr,letskorail.com
PAYMENT_TRANSPORT_TRUST_ENV=false
PAYMENT_REQUIRE_CVV_KEK_VERSION=false
EMAIL_PROVIDER=resend
EMAIL_FROM_NAME=bominal
EMAIL_FROM_ADDRESS=no-reply@CHANGE_ME_RESEND_DOMAIN
EMAIL_REPLY_TO=support@bominal.com
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
RESEND_API_BASE_URL=https://api.resend.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=10
