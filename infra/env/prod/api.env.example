# Copy to infra/env/prod/api.env before running production compose
APP_ENV=production
# Required by deploy.sh to resolve Artifact Registry image paths.
GCP_PROJECT_ID=CHANGE_ME_GCP_PROJECT_ID
DATABASE_URL=postgresql+asyncpg://bominal:CHANGE_ME_STRONG_PASSWORD@postgres:5432/bominal
SYNC_DATABASE_URL=postgresql+psycopg://bominal:CHANGE_ME_STRONG_PASSWORD@postgres:5432/bominal
CORS_ORIGINS=https://www.bominal.com
SESSION_COOKIE_NAME=bominal_session
SESSION_DAYS_DEFAULT=7
SESSION_DAYS_REMEMBER=90
# legacy | supabase | dual
AUTH_MODE=supabase
SUPABASE_URL=CHANGE_ME_SUPABASE_URL
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=CHANGE_ME_SUPABASE_JWT_ISSUER
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_STORAGE_ENABLED=false
SUPABASE_STORAGE_BUCKET=artifacts-safe
SUPABASE_SERVICE_ROLE_KEY=
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_USE_REDIS=1
# Non-CDE Redis (queues/rate limits/safe cache)
REDIS_URL=redis://redis:6379/0
# Optional explicit split URLs.
# If REDIS_URL_CDE is empty, REDIS_URL is used for CDE; it MUST NOT be Upstash.
REDIS_URL_NON_CDE=
REDIS_URL_CDE=
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_API_KEY
# Generate with: openssl rand -base64 32
MASTER_KEY=CHANGE_ME_BASE64_32_BYTES
KEK_VERSION=1
TRAIN_PROVIDER_MODE=real
TRAIN_PROVIDER_TRANSPORT=curl_cffi
TRAIN_POLL_MIN_SECONDS=2
TRAIN_POLL_MAX_SECONDS=6
TRAIN_CREDENTIAL_VERIFY_TIMEOUT_SECONDS=8
TRAIN_CREDENTIAL_CACHE_SECONDS=3600
RESTAURANT_AUTH_REFRESH_RETRIES=2
RESTAURANT_PAYMENT_LEASE_TTL_SECONDS=120
RESTAURANT_BOOTSTRAP_TIMEOUT_SECONDS=20
PAYMENT_CVV_TTL_SECONDS=600
PAYMENT_CVV_TTL_MIN_SECONDS=60
PAYMENT_CVV_TTL_MAX_SECONDS=900
PAYMENT_PROVIDER_ALLOWED_HOSTS=app.srail.or.kr,smart.letskorail.com
PAYMENT_TRANSPORT_TRUST_ENV=false
PAYMENT_REQUIRE_CVV_KEK_VERSION=false
EMAIL_PROVIDER=resend
EMAIL_FROM_NAME=bominal
EMAIL_FROM_ADDRESS=no-reply@CHANGE_ME_RESEND_DOMAIN
EMAIL_REPLY_TO=support@bominal.com
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
RESEND_API_BASE_URL=https://api.resend.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=10
