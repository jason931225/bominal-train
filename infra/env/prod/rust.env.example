## Legacy Rust runtime env template (deprecated).
## Use infra/env/prod/runtime.env.example for active production configuration.
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_JSON=true

# Rust runtime expects postgres:// or postgresql:// URL scheme.
DATABASE_URL=postgres://bominal:CHANGE_ME@db-host:5432/bominal

SUPABASE_URL=https://CHANGE_ME.supabase.co
SUPABASE_JWT_ISSUER=https://CHANGE_ME.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_URL=https://CHANGE_ME.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_CACHE_SECONDS=300
SUPABASE_AUTH_WEBHOOK_SECRET=CHANGE_ME

REDIS_URL=redis://redis:6379/0
RUNTIME_QUEUE_KEY=train:queue
RUNTIME_QUEUE_DLQ_KEY=train:queue:dlq
RUNTIME_LEASE_PREFIX=train:lease
RUNTIME_RATE_LIMIT_PREFIX=rate_limit

EVERVAULT_RELAY_BASE_URL=https://relay.evervault.com
EVERVAULT_APP_ID=

RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com
EMAIL_FROM_ADDRESS=no-reply@bominal.com

WORKER_POLL_SECONDS=3
WORKER_RECONCILE_SECONDS=30
WORKER_WATCH_SECONDS=5
KEY_ROTATION_SECONDS=3600

FRONTEND_ASSETS_DIR=/app/frontend/dist
