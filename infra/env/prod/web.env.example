# Copy to infra/env/prod/web.env before running production compose
# Keep browser requests same-origin to preserve SameSite=Lax session cookies.
NEXT_PUBLIC_API_BASE_URL=
# Internal server-side URL used by Next.js server runtime
API_SERVER_URL=http://api:8000
NEXT_PUBLIC_TRAIN_AUTO_PAY_ENABLED=true
NEXT_PUBLIC_TRAIN_KTX_ENABLED=false
NEXT_PUBLIC_RESTAURANT_MODULE_ENABLED=false
NEXT_PUBLIC_SUPABASE_DIRECT_AUTH_ENABLED=true
NEXT_PUBLIC_SUPABASE_REALTIME_ENABLED=true
NEXT_PUBLIC_SUPABASE_REALTIME_DELTA_READ_ENABLED=true
NEXT_PUBLIC_TRAIN_READS_VIA_DATA_API=false
NEXT_PUBLIC_TRAIN_DETAIL_VIA_GRAPHQL=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_EVERVAULT_TEAM_ID=
NEXT_PUBLIC_EVERVAULT_APP_ID=
# Optional: remote hosted font assets (same pattern as landing video assets).
# Expected files:
# - NotoSansKR-Regular.woff2
# - NotoSerifKR-Regular.woff2
# - NotoSerifKR-SemiBold.woff2
# - NotoSerifKR-Bold.woff2
# - DynaPuff-SemiBold.woff2
NEXT_PUBLIC_FONT_BASE_URL=https://github.com/jason931225/bominal.github.io/raw/refs/heads/main/public/font
NODE_ENV=production
