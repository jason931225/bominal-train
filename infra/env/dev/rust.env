APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_JSON=false

DATABASE_URL=postgres://bominal:bominal@postgres:5432/bominal

SUPABASE_URL=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_URL=
SUPABASE_JWKS_CACHE_SECONDS=300
SUPABASE_AUTH_WEBHOOK_SECRET=

REDIS_URL=redis://redis:6379/0
RUNTIME_QUEUE_KEY=train:queue
RUNTIME_QUEUE_DLQ_KEY=train:queue:dlq
RUNTIME_LEASE_PREFIX=train:lease
RUNTIME_RATE_LIMIT_PREFIX=rate_limit

EVERVAULT_RELAY_BASE_URL=https://relay.evervault.com
EVERVAULT_APP_ID=

RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com
EMAIL_FROM_ADDRESS=no-reply@bominal.local

WORKER_POLL_SECONDS=3
WORKER_RECONCILE_SECONDS=30
WORKER_WATCH_SECONDS=5
KEY_ROTATION_SECONDS=3600

FRONTEND_ASSETS_DIR=/workspace/rust/frontend/dist
