APP_ENV=development
# Local development must use Docker-local Postgres + Redis (no VM/remote Postgres URL).
DATABASE_URL=postgresql+asyncpg://bominal:bominal@postgres:5432/bominal
DATABASE_URL_TARGET=pooler
DATABASE_URL_DIRECT=
SYNC_DATABASE_URL=postgresql+psycopg://bominal:bominal@postgres:5432/bominal
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=600
DB_POOL_USE_LIFO=true
DB_CONNECT_TIMEOUT_SECONDS=5
DB_COMMAND_TIMEOUT_SECONDS=8
DB_STATEMENT_TIMEOUT_MS=12000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000
SESSION_COOKIE_NAME=bominal_session
SESSION_DAYS_DEFAULT=7
SESSION_DAYS_REMEMBER=90
AUTH_REGISTRATION_ENABLED=true
AUTH_MODE=legacy
# Dev-only auth bypass for UI walkthroughs without signing in.
DEV_AUTH_BYPASS_ENABLED=false
DEV_AUTH_BYPASS_EMAIL=dev-bypass@bominal.local
DEV_AUTH_BYPASS_ROLE=admin
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SIGNIN_OTP_ENABLED=false
SUPABASE_STORAGE_ENABLED=false
SUPABASE_STORAGE_BUCKET=artifacts-safe
SUPABASE_SERVICE_ROLE_KEY=
EDGE_TASK_NOTIFY_ENABLED=false
SUPABASE_EDGE_FUNCTIONS_BASE_URL=
SUPABASE_EDGE_TASK_NOTIFY_FUNCTION_NAME=task-notify
SUPABASE_EDGE_TIMEOUT_SECONDS=8
PASSKEY_ENABLED=true
# Local WebAuthn support is most consistent on localhost origin.
PASSKEY_RP_ID=localhost
PASSKEY_ORIGIN=http://localhost:3000
PASSKEY_TIMEOUT_MS=60000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20
# Non-CDE Redis (queues/rate limits/safe cache)
REDIS_URL=redis://redis:6379/0
# Optional explicit split URLs
REDIS_URL_NON_CDE=
REDIS_URL_CDE=
INTERNAL_API_KEY=dev-internal-api-key
INTERNAL_IDENTITY_SECRET=dev-internal-identity-secret
INTERNAL_IDENTITY_ISSUER=bominal-internal
INTERNAL_IDENTITY_TTL_SECONDS=120
GCP_PROJECT_ID=
GSM_MASTER_KEY_ENABLED=false
GSM_MASTER_KEY_PROJECT_ID=
GSM_MASTER_KEY_SECRET_ID=bominal-master-key
GSM_MASTER_KEY_VERSION=latest
GSM_MASTER_KEY_ALLOW_ENV_FALLBACK=true
MASTER_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
MASTER_KEY_OVERRIDE=
MASTER_KEYS_BY_VERSION=
KEK_VERSION=1
KEK_RETIREMENT_WINDOW_DAYS=30
TRAIN_PROVIDER_MODE=real
TRAIN_PROVIDER_TRANSPORT=curl_cffi
TRAIN_PROVIDER_EGRESS_PROXY_URL=http://egress-train:8080
TRAIN_KTX_ENABLED=true
RESTAURANT_PROVIDER_EGRESS_PROXY_URL=http://egress-restaurant:8080
RESTAURANT_MODULE_ENABLED=true
TRAIN_POLL_MIN_SECONDS=2
TRAIN_POLL_MAX_SECONDS=6
TRAIN_POLL_FORCE_MAX_RATE=false
TRAIN_PERSIST_ALL_ATTEMPTS=false
TRAIN_ATTEMPT_RETENTION_DAYS=30
TRAIN_COMPACT_REPETITIVE_ATTEMPTS=true
TRAIN_SYNC_KEEP_LATEST_ONLY=true
TRAIN_CREDENTIAL_VERIFY_TIMEOUT_SECONDS=8
TRAIN_CREDENTIAL_CACHE_SECONDS=3600
TRAIN_KTX_AUTH_DYNAPATH_TOKEN=<redacted>
RESTAURANT_AUTH_REFRESH_RETRIES=2
RESTAURANT_PAYMENT_LEASE_TTL_SECONDS=120
RESTAURANT_BOOTSTRAP_TIMEOUT_SECONDS=20
PAYMENT_ENABLED=false
PAYMENT_CVV_TTL_SECONDS=600
PAYMENT_CVV_TTL_MIN_SECONDS=60
PAYMENT_CVV_TTL_MAX_SECONDS=900
PAYMENT_PROVIDER=evervault
PAYMENT_EVERVAULT_ENFORCE=true
AUTOPAY_REQUIRE_USER_WALLET=true
AUTOPAY_ALLOW_SERVER_FALLBACK=false
PAYMENT_PROVIDER_ALLOWED_HOSTS=app.srail.or.kr,letskorail.com
PAYMENT_TRANSPORT_TRUST_ENV=false
PAYMENT_REQUIRE_CVV_KEK_VERSION=false
EMAIL_PROVIDER=smtp
EMAIL_FROM_NAME=bominal
EMAIL_FROM_ADDRESS=no-reply@bominal.local
EMAIL_REPLY_TO=
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false
SMTP_STARTTLS=false
SMTP_TIMEOUT_SECONDS=10
EVERVAULT_APP_ID=
EVERVAULT_API_KEY=
