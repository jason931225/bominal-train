#!/usr/bin/env bash
# bominal-monitor - Wrapper script to run the bominal monitor CLI
#
# Usage:
#   bominal-monitor           # One-time snapshot
#   bominal-monitor --watch   # Live refresh mode
#   bominal-monitor -w -i 5   # Refresh every 5 seconds
#
# Can be run:
#   - On VM directly: /opt/bominal/repo/infra/scripts/bominal-monitor
#   - In API container: python -m app.monitor
#   - Via docker exec: docker compose exec api-gateway python -m app.monitor

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
source "$SCRIPT_DIR/lib/env_utils.sh"

# Check if running inside container or on host
if [[ -f "/.dockerenv" ]]; then
    # Inside container
    cd /app
    exec python -m app.monitor "$@"
else
    detect_compose_cmd
    COMPOSE_FILE="$(resolve_compose_file "$REPO_ROOT")"
    API_SERVICE="$(first_running_compose_service "$COMPOSE_FILE" "api-gateway" "api" || true)"
    if [[ -z "$API_SERVICE" ]]; then
        echo "Error: api-gateway service is not running for compose file: $COMPOSE_FILE"
        echo "Start the stack before running bominal-monitor."
        exit 1
    fi

    # On host - show container status first, then run monitor in container
    # Print container status from host (where docker works)
    echo ""
    echo "Container Status (from host)"
    echo "============================================================"
    "${COMPOSE_CMD[@]}" -f "$COMPOSE_FILE" ps --format "table {{.Name}}\t{{.Status}}" 2>/dev/null || echo "  Unable to get container status"
    echo ""
    
    # Run the rest of the monitor inside the container
    exec "${COMPOSE_CMD[@]}" -f "$COMPOSE_FILE" exec -T "$API_SERVICE" python -m app.monitor "$@"
fi
