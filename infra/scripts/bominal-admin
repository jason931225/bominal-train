#!/usr/bin/env bash
# bominal-admin - Wrapper script to run the bominal admin CLI
#
# Usage:
#   bominal-admin user list
#   bominal-admin user promote admin@example.com
#   bominal-admin task list --all
#   bominal-admin db stats
#
# Run on production:
#   /opt/bominal/repo/infra/scripts/bominal-admin user list

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
source "$SCRIPT_DIR/lib/env_utils.sh"

# Check if running inside container or on host
if [[ -f "/.dockerenv" ]]; then
    # Inside container
    cd /app
    exec python -m app.admin_cli "$@"
else
    detect_compose_cmd
    COMPOSE_FILE="$(resolve_compose_file "$REPO_ROOT")"
    if ! compose_service_is_running "$COMPOSE_FILE" "api"; then
        echo "Error: api service is not running for compose file: $COMPOSE_FILE"
        echo "Start the stack before running bominal-admin."
        exit 1
    fi
    exec "${COMPOSE_CMD[@]}" -f "$COMPOSE_FILE" exec -T api python -m app.admin_cli "$@"
fi
