# Bominal Train Reservation — Caddy reverse proxy
# Replace bominal.example.com with your actual domain.
# Caddy handles TLS automatically via Let's Encrypt.

bominal.example.com {
    # Static assets with Brotli/gzip pre-compression and immutable cache
    handle /pkg/* {
        root * /opt/bominal/site
        file_server {
            precompressed br gzip
        }
        header Cache-Control "public, max-age=31536000, immutable"
    }

    handle /assets/* {
        root * /opt/bominal/site
        file_server {
            precompressed br gzip
        }
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # SSE endpoint — disable buffering for real-time events
    handle /api/events {
        reverse_proxy localhost:3000 {
            flush_interval -1
        }
    }

    # All other traffic to the Leptos/Axum server
    handle {
        reverse_proxy localhost:3000
    }
}
