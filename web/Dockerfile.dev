FROM node:24-alpine

WORKDIR /app

# Keep default web container lightweight and browser-free.
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

RUN apk add --no-cache \
    git \
    python3 \
    ca-certificates

COPY package.json package-lock.json ./
RUN npm ci

CMD ["npm", "run", "dev", "--", "-H", "0.0.0.0", "-p", "3000"]
