FROM node:24-alpine

WORKDIR /app

# E2E image intentionally includes Chromium for Playwright.
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

RUN apk add --no-cache \
    git \
    python3 \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont

COPY package.json package-lock.json ./
RUN npm ci

CMD ["npm", "run", "test:e2e"]
